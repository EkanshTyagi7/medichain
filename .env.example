# ─── DATABASE ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/medichain?schema=public"

# ─── AUTH ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── DIGILOCKER OAUTH ─────────────────────────────────
DIGILOCKER_CLIENT_ID=""
DIGILOCKER_CLIENT_SECRET=""
DIGILOCKER_REDIRECT_URI="http://localhost:3000/api/auth/digilocker"

# ─── PINATA / IPFS ────────────────────────────────────
PINATA_API_KEY=""
PINATA_SECRET_API_KEY=""
PINATA_GATEWAY="https://gateway.pinata.cloud/ipfs"

# ─── BLOCKCHAIN ───────────────────────────────────────
NEXT_PUBLIC_POLYGON_RPC="https://rpc-amoy.polygon.technology"
NEXT_PUBLIC_CHAIN_ID="80002"
NEXT_PUBLIC_PRESCRIPTION_CONTRACT_ADDRESS=""
NEXT_PUBLIC_MEDICINE_BATCH_CONTRACT_ADDRESS=""
NEXT_PUBLIC_AUDIT_CONTRACT_ADDRESS=""
