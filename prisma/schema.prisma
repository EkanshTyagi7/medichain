generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────

enum Role {
  CITIZEN
  DOCTOR
  PHARMACY
  REGULATOR
}

enum PrescriptionStatus {
  CREATED
  VERIFIED
  DISPENSED
  EXPIRED
}

// ─── MODELS ───────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  role          Role
  walletAddress String?  @unique
  createdAt     DateTime @default(now())

  prescriptionsAsDoctor  Prescription[] @relation("DoctorPrescriptions")
  prescriptionsAsPatient Prescription[] @relation("PatientPrescriptions")
  dispensedByPharmacy    Prescription[] @relation("PharmacyDispensed")
  auditLogs              AuditLog[]
}

model Prescription {
  id             String             @id @default(cuid())
  prescriptionId String             @unique
  doctorId       String
  patientId      String
  ipfsHash       String
  txHash         String?
  status         PrescriptionStatus @default(CREATED)
  expiryDate     DateTime
  createdAt      DateTime           @default(now())

  // Dispensing fields (merged from DispenseRecord)
  pharmacyId     String?
  dispensedAt    DateTime?

  doctor         User               @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  patient        User               @relation("PatientPrescriptions", fields: [patientId], references: [id])
  pharmacy       User?              @relation("PharmacyDispensed", fields: [pharmacyId], references: [id])
  items          PrescriptionItem[]

  @@index([doctorId])
  @@index([patientId])
  @@index([pharmacyId])
  @@index([status])
}

model PrescriptionItem {
  id             String @id @default(cuid())
  prescriptionId String
  medicineName   String
  dosage         String
  duration       String
  quantity       Int
  instructions   String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  action    String
  entityId  String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityId])
  @@index([timestamp])
}
